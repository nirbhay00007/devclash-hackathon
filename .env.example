# DEV_CLASH — Environment Variables
# Copy this file to backend/.env and fill in your values.

# ── Gemini AI (required for global repo analysis) ─────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Node ML Backend ───────────────────────────────────────────────────────────
PORT=3001

# ── Java AST Backend connection (Node calls Java for GitHub/Java repos) ────────
JAVA_BACKEND_HOST=localhost
JAVA_BACKEND_PORT=8080
